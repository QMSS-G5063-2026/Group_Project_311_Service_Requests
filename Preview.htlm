<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NYC 311 Neighborhood Issues Explorer</title>
  <style>
    * { box-sizing: border-box; }
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #14213d;
      --muted: #5b6475;
      --accent: #1d4ed8;
      --accent-soft: #dbeafe;
      --border: #e5e7eb;
      --shadow: 0 10px 30px rgba(20, 33, 61, 0.08);
    }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.5;
    }
    header {
      background: linear-gradient(135deg, #0f172a, #1d4ed8);
      color: white;
      padding: 3.5rem 1.5rem 2.5rem;
    }
    .container {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
    }
    .eyebrow {
      display: inline-block;
      background: rgba(255,255,255,0.16);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 999px;
      padding: 0.35rem 0.8rem;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    h1, h2, h3 { margin-top: 0; }
    h1 {
      font-size: clamp(2rem, 5vw, 3.6rem);
      line-height: 1.1;
      margin-bottom: 1rem;
    }
    .hero-text {
      max-width: 760px;
      font-size: 1.05rem;
      color: rgba(255,255,255,0.9);
      margin-bottom: 1.5rem;
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
    }
    .btn {
      display: inline-block;
      padding: 0.8rem 1.1rem;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      border: 1px solid transparent;
    }
    .btn-primary {
      background: white;
      color: #0f172a;
    }
    .btn-secondary {
      background: transparent;
      color: white;
      border-color: rgba(255,255,255,0.28);
    }
    main {
      padding: 2rem 0 4rem;
    }
    .section {
      margin-bottom: 1.5rem;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 1.4rem;
      box-shadow: var(--shadow);
    }

    /* Explore section highlight */
    #explore {
      background: linear-gradient(135deg, #dbeafe, #e0f2fe);
      border: 1px solid #bfdbfe;
    }

    #explore h2 {
      color: #1d4ed8;
      font-weight: 700;
    }
    .grid {
      display: grid;
      gap: 1rem;
    }
    .grid-2 {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
    .grid-3 {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 0.8rem;
    }
    .pill {
      padding: 0.55rem 0.85rem;
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: 0.95rem;
    }
    .filters {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }
    label {
      display: block;
      font-size: 0.92rem;
      color: var(--muted);
      margin-bottom: 0.4rem;
      font-weight: 600;
    }
    select {
      width: 100%;
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: white;
      font-size: 1rem;
    }
    .stat {
      border-radius: 18px;
      padding: 1rem;
      color: #0f172a;
      border: none;
    }

    /* Unified blue shades for audience boxes */
    .stat:nth-child(1){background:#dbeafe;} 
    .stat:nth-child(2){background:#bfdbfe;} 
    .stat:nth-child(3){background:#93c5fd;} 
    .stat:nth-child(4){background:#c7d2fe;} 
    .stat:nth-child(5){background:#a5b4fc;} 
    .stat:nth-child(6){background:#e0f2fe;} 
    .stat:nth-child(7){background:#bae6fd;} 
    .stat:nth-child(8){background:#bfdbfe;} 
    .stat:nth-child(9){background:#c4b5fd;} 
    .stat:nth-child(10){background:#ddd6fe;} 
    .stat strong {
      display: block;
      font-size: 1.65rem;
      margin-bottom: 0.25rem;
    }
    .placeholder {
      min-height: 250px;
      border: 2px dashed #cbd5e1;
      background: linear-gradient(180deg, #f8fbff, #eef4ff);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 1rem;
      color: var(--muted);
      font-weight: 600;
    }
    .list {
      padding-left: 1.2rem;
      margin: 0.6rem 0 0;
    }
    .list li { margin-bottom: 0.45rem; }
    .comparison {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .borough-box {
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 0.9rem;
      text-align: center;
    }
    .muted { color: var(--muted); }
    footer {
      padding: 2rem 0 3rem;
      color: var(--muted);
      text-align: center;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="eyebrow">Public data • neighborhood insights • interactive visualizations</div>
      <h1>NYC 311 Neighborhood Issues Explorer</h1>
      <p class="hero-text">
        Explore NYC using New York City 311 complaint data by borough, by neighborhood, by audience group, or complaint type.<br /><br />Designed to help residents, researchers, and decision-makers understand quality of life issues across the city through maps, trends, comparisons, and future analytics.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#explore">Start Exploring</a>
        <a class="btn btn-secondary" href="#insights">See Deep Analytics</a>
      </div>
    </div>
  </header>

  <main>
    <div class="container">
      <section class="section card" id="explore">
        <h2>Explore the Data</h2>
        <p class="muted">Layout can be refined later. For now, this page gives a strong homepage structure for the project.</p>
        <div class="pill-row">
          <span class="pill">Explore by Area</span>
          <span class="pill">By Audience</span>
          <span class="pill">By Complaint Type</span>
          <span class="pill">Map</span>
          <span class="pill">Trends</span>
          <span class="pill">Compare Neighborhoods</span>
        </div>
        <div class="filters">
          <div>
            <label for="borough">Select Borough</label>
            <select id="borough">
              <option>All Boroughs</option>
              <option>Manhattan</option>
              <option>Bronx</option>
              <option>Brooklyn</option>
              <option>Queens</option>
              <option>Staten Island</option>
            </select>
          </div>
          <div>
            <label for="neighborhood">Select Neighborhood</label>
            <select id="neighborhood">
              <option>Select a borough first</option>
            </select>
          </div>
          <div>
            <label for="complaint">Select Complaint Type</label>
            <select id="complaint">
              <option value="">Select Complaint Category</option>

              <optgroup label="Families with Children">
                <option>Noise - Residential</option>
                <option>Noise - Street/Sidewalk</option>
                <option>Rodent</option>
                <option>Dirty Condition</option>
                <option>School Maintenance</option>
                <option>Unleashed Dog</option>
                <option>Food Establishment</option>
                <option>Indoor Air Quality</option>
                <option>Heat / Air Conditioning Issues</option>
              </optgroup>

              <optgroup label="Older Adults">
                <option>Broken Sidewalk</option>
                <option>Sidewalk Violation</option>
                <option>Street Light Out</option>
                <option>Elevator Complaints</option>
                <option>Heat / No Heat</option>
                <option>Water System Issues</option>
                <option>Homeless Person Assistance</option>
                <option>Illegal Parking Blocking Access</option>
                <option>Blocked Driveway</option>
                <option>Noise Complaints</option>
              </optgroup>

              <optgroup label="Tenants / Residents">
                <option>Noise - Residential</option>
                <option>Lead</option>
                <option>Rodent</option>
                <option>Water Issues</option>
                <option>Sewer Backup</option>
                <option>Illegal Conversion</option>
                <option>Building Permit Issues</option>
                <option>Elevator</option>
                <option>Indoor Air Quality</option>
                <option>Mold</option>
                <option>Missed Collection</option>
                <option>Dirty Condition</option>
              </optgroup>

              <optgroup label="Pedestrians / Wheelchair Users">
                <option>Broken Sidewalk</option>
                <option>Sidewalk Violation</option>
                <option>Blocked Sidewalk</option>
                <option>Blocked Crosswalk</option>
                <option>Blocked Bike Lane</option>
                <option>Curb Condition</option>
                <option>Pedestrian Signal</option>
                <option>Street Light Out</option>
                <option>Outdoor Dining Sidewalk Blockage</option>
                <option>Obstruction</option>
              </optgroup>

              <optgroup label="Drivers / Commuters">
                <option>Illegal Parking</option>
                <option>Blocked Driveway</option>
                <option>Traffic Congestion</option>
                <option>Chronic Speeding</option>
                <option>Potholes</option>
                <option>Street Condition</option>
                <option>Traffic Signal Issues</option>
                <option>Double Parking</option>
                <option>Unauthorized Bus Layover</option>
                <option>Vehicle Noise / Idling</option>
              </optgroup>

              <optgroup label="Small Business Owners">
                <option>Outdoor Dining Issues</option>
                <option>Unauthorized Outdoor Seating</option>
                <option>Sidewalk Obstruction</option>
                <option>Illegal Vending</option>
                <option>Unlicensed Vendors</option>
              </optgroup>

              <optgroup label="Pet Owners">
                <option>Unleashed Dog</option>
                <option>Animal Abuse</option>
                <option>Barking Dog</option>
                <option>Dangerous Dog</option>
                <option>Dog Park Issues</option>
              </optgroup>

              <optgroup label="Public Health / Neighborhood Safety">
                <option>Rodent</option>
                <option>Food Establishment</option>
                <option>Smoking or Vaping</option>
                <option>Indoor Air Quality</option>
                <option>Lead</option>
                <option>Water Quality</option>
                <option>Sewer Backup</option>
                <option>Standing Water</option>
                <option>Unsanitary Conditions</option>
                <option>Noise (Health Related)</option>
              </optgroup>

              <optgroup label="General Neighborhood / Quality of Life">
                <option>Dirty Condition</option>
                <option>Missed Collection</option>
                <option>Illegal Dumping</option>
                <option>Graffiti</option>
                <option>Dead Animal</option>
                <option>Street Sweeping Complaint</option>
                <option>Litter Basket Complaint</option>
                <option>Snow or Ice</option>
                <option>Obstruction</option>
                <option>Abandoned Vehicle</option>
              </optgroup>

              <optgroup label="Safety and Enforcement">
                <option>Drug Activity</option>
                <option>Trespassing</option>
                <option>Disorderly Youth</option>
                <option>Animal Abuse</option>
                <option>Illegal Building Use</option>
                <option>Work Without Permit</option>
                <option>Traffic Safety</option>
                <option>Street Light Outages</option>
                <option>Homeless Person Assistance</option>
              </optgroup>

            </select>
          </div>
        </div>
      </section>

      <section class="section grid grid-3">
        <div class="stat">
          <strong>👨‍👩‍👧 Families with Children</strong>
          <span class="muted">Complaints that affect kids, schools, home safety, and neighborhood cleanliness.</span>
        </div>
        <div class="stat">
          <strong>🚗 Drivers / Commuters</strong>
          <span class="muted">Focus on transportation, parking, congestion, road conditions, and daily travel issues.</span>
        </div>
        <div class="stat">
          <strong>🏙️ General Neighborhood / Quality of Life</strong>
          <span class="muted">An intuitive category for cleanliness, dumping, graffiti, litter, and everyday street conditions.</span>
        </div>
        <div class="stat">
          <strong>🧓 Older Adults</strong>
          <span class="muted">Focus on mobility, safety, building services, access, and basic living conditions.</span>
        </div>
        <div class="stat">
          <strong>🚶 Pedestrians / Wheelchair Users</strong>
          <span class="muted">Public-interest information about sidewalks, crossings, obstructions, and accessibility barriers.</span>
        </div>
        <div class="stat">
          <strong>🐕 Pet Owners</strong>
          <span class="muted">Issues related to dogs, parks, barking, safety, and animal welfare in neighborhoods.</span>
        </div>
        <div class="stat">
          <strong>🩺 Public Health / Neighborhood Safety</strong>
          <span class="muted">Meaningful and policy-relevant complaints tied to sanitation, health risks, and environmental concerns.</span>
        </div>
        <div class="stat">
          <strong>🚨 Safety and Enforcement</strong>
          <span class="muted">Complaints people connect with feeling unsafe, disorder, illegal activity, and enforcement concerns.</span>
        </div>
        <div class="stat">
          <strong>🏪 Small Business Owners</strong>
          <span class="muted">Concerns tied to storefront access, vending, sidewalk use, and outdoor dining operations.</span>
        </div>
        <div class="stat">
          <strong>🏢 Tenants / Residents</strong>
          <span class="muted">Know what you do not know before you need to know it, with issues tied to housing and building conditions.</span>
        </div>
      </section>

      <section class="section grid grid-2">
        <div class="card">
          <h2>Explore by Audience</h2>
          <p class="muted">Help users discover issues most relevant to their daily lives.</p>
          <div class="pill-row">
            <span class="pill">Families with Children</span>
            <span class="pill">Older Adults</span>
            <span class="pill">Tenants</span>
            <span class="pill">Accessibility Needs</span>
            <span class="pill">Commuters</span>
            <span class="pill">Public Health</span>
            <span class="pill">Neighborhood Cleanliness</span>
          </div>
        </div>
        <div class="card">
          <h2>Audience Group Showcase</h2>
          <ul class="list">
            <li>Top complaints for the selected audience group</li>
            <li>Complaints by neighborhood</li>
            <li>Complaint trends over time</li>
            <li>Map of complaints</li>
          </ul>
        </div>
      </section>

      <section class="section grid grid-2">
        <div class="card">
          <h2>Map Area</h2>
          <div class="placeholder">Interactive complaint map placeholder<br />Borough / neighborhood / point or heat map</div>
        </div>
        <div class="card">
          <h2>Trends Area</h2>
          <div class="placeholder">Trend chart placeholder<br />Complaints over time, rankings, time patterns</div>
        </div>
      </section>

      <section class="section card">
        <h2>The Complaint Battle</h2>
        <p class="muted">Compare boroughs side by side to see which issues dominate where.</p>
        <div class="comparison">
          <div class="borough-box"><strong>Manhattan</strong><br /><span class="muted">vs others</span></div>
          <div class="borough-box"><strong>Bronx</strong><br /><span class="muted">vs others</span></div>
          <div class="borough-box"><strong>Brooklyn</strong><br /><span class="muted">vs others</span></div>
          <div class="borough-box"><strong>Queens</strong><br /><span class="muted">vs others</span></div>
          <div class="borough-box"><strong>Staten Island</strong><br /><span class="muted">vs others</span></div>
        </div>
      </section>

      <section class="section grid grid-2" id="insights">
        <div class="card">
          <h2>Advanced Features</h2>
          <ul class="list">
            <li>Street view</li>
            <li>Block view</li>
            <li>Neighborhood drill-down</li>
            <li>Future predictive visualizations</li>
          </ul>
        </div>
        <div class="card">
          <h2>Deep Analytics and Insights</h2>
          <ul class="list">
            <li>Which neighborhoods have the most complaints?</li>
            <li>Which complaints are increasing?</li>
            <li>Which complaints affect families the most?</li>
            <li>Worst street by complaints in NYC</li>
            <li>Top complaint trends</li>
            <li>Rankings and time patterns</li>
          </ul>
        </div>
      </section>
    </div>
  </main>

  <footer>
    <div class="container">
      Prototype homepage for a public NYC 311 data website. Next step: connect real data and add interactive charts and maps.
    </div>
  </footer>
  <script>
    const neighborhoods = {
      "Manhattan": ["Harlem", "Upper East Side", "Upper West Side", "Chelsea", "SoHo", "Tribeca", "Lower East Side"],
      "Bronx": ["Riverdale", "Fordham", "Mott Haven", "Kingsbridge", "Pelham Bay"],
      "Brooklyn": ["Williamsburg", "Park Slope", "Bushwick", "Brooklyn Heights", "Bedford-Stuyvesant"],
      "Queens": ["Astoria", "Flushing", "Long Island City", "Jamaica", "Forest Hills"],
      "Staten Island": ["St. George", "Tottenville", "Great Kills", "New Dorp"]
    };

    const boroughSelect = document.getElementById("borough");
    const neighborhoodSelect = document.getElementById("neighborhood");

    function populateNeighborhoods(borough) {
      neighborhoodSelect.innerHTML = "";

      const defaultOption = document.createElement("option");
      defaultOption.value = "";

      if (!neighborhoods[borough]) {
        defaultOption.textContent = "Select a borough first";
        neighborhoodSelect.appendChild(defaultOption);
        return;
      }

      defaultOption.textContent = "Choose a Neighborhood";
      neighborhoodSelect.appendChild(defaultOption);

      neighborhoods[borough].forEach((n) => {
        const option = document.createElement("option");
        option.value = n;
        option.textContent = n;
        neighborhoodSelect.appendChild(option);
      });
    }

    boroughSelect.addEventListener("change", function () {
      populateNeighborhoods(this.value);
    });

    populateNeighborhoods(boroughSelect.value);
  </script>
</body>
</html>
